# Required for OpenRouter mode
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# Required for prompt proxy route when LLM is enabled
PROMPT_PROXY_API_KEY=replace-with-long-random-secret

# Optional (for plain docker run; docker compose fixes internal app port to 8080)
PORT=8080
# LLM_PROVIDER=openrouter
# METRICS_PROMETHEUS_ENABLED=true
