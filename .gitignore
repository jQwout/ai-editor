# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/

# Local configuration file (sdk path, etc)
local.properties

# Android Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Kotlin
.kotlin/

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log

# Temporary files
*.tmp
*.swp
*~

# Local CLI tools and binaries
~/.local/bin/
~/.uv/

# Keystore files (security)
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Android Profiling
*.hprof

# Backend specific (if applicable)
backend/build/
